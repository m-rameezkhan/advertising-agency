{
  "name": "ad-agency-saas-suite",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:ai": "npm --workspace apps/ai-service run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "start": "npm-run-all --parallel dev:web dev:api dev:ai"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
